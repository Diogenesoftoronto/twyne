{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20",
    "bun": "1"
  },
  "steps": {
    "build": {
      "inputs": [
        { "step": "install" },
        { "local": true, "include": ["."], "exclude": ["node_modules"] }
      ],
      "commands": ["bash scripts/railway-build.sh"]
    }
  },
  "deploy": {
    "startCommand": "node server.js"
  }
}
